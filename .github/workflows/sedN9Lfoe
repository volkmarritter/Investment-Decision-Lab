name: Refresh ETF core fields (weekly justETF snapshot)

# Snapshot-build data pipeline.
# Runs the refresh script once per week, commits any diff in the override JSON
# and lets the normal deploy job ship the new bundle. The app stays
# frontend-only at runtime — no live API call from the browser.
#
# This workflow only refreshes the "core" fund metadata (TER / AUM / inception
# / distribution / replication). The per-exchange listings map is refreshed on
# a separate nightly schedule (see refresh-listings.yml) and the per-ISIN
# top-holdings list is refreshed monthly (see refresh-lookthrough.yml).
# Trigger an out-of-band refresh via workflow_dispatch whenever needed.

on:
  schedule:
    - cron: "0 3 * * 0" # 03:00 UTC every Sunday
  workflow_dispatch: # allow manual triggering from the Actions tab

# Serialise with refresh-listings.yml: both jobs commit to the same
# etfs.overrides.json. The shared concurrency group prevents push races
# (non-fast-forward failures) when a weekly and a nightly run overlap, e.g.
# after a manual workflow_dispatch.
concurrency:
  group: etf-overrides-write
  cancel-in-progress: false

permissions:
  contents: write # required to commit the refreshed JSON

jobs:
  refresh:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - uses: pnpm/action-setup@v4
        with:
          version: 10

      - uses: actions/setup-node@v4
        with:
          node-version: 20
          cache: pnpm

      - run: pnpm install --frozen-lockfile

      - name: Refresh core ETF overrides from justETF (weekly)
        working-directory: artifacts/investment-lab
        run: node scripts/refresh-justetf.mjs --mode=core

      - name: Run typecheck and tests against the new snapshot
        working-directory: artifacts/investment-lab
        run: |
          pnpm run typecheck
          pnpm run test

      - name: Commit & push if changed
        # The run-log file is always touched by the script (one row per run,
        # success or fail), so this commit step always has something to push
        # — even when no actual override data changed. That guarantees every
        # scheduled invocation leaves a git commit and a Trigger-tagged row in
        # src/data/refresh-runs.log.md.
        run: |
          git add artifacts/investment-lab/src/data/etfs.overrides.json artifacts/investment-lab/src/data/refresh-runs.log.md artifacts/investment-lab/src/data/refresh-changes.log.jsonl || true
          if [[ -n "$(git status --porcelain artifacts/investment-lab/src/data/etfs.overrides.json artifacts/investment-lab/src/data/refresh-runs.log.md artifacts/investment-lab/src/data/refresh-changes.log.jsonl)" ]]; then
            git config user.name  "github-actions[bot]"
            git config user.email "41898282+github-actions[bot]@users.noreply.github.com"
            git commit -m "chore(data): weekly justETF core snapshot $(date -u +%Y-%m-%d)"
            # Retry push once on non-fast-forward (e.g. a human commit landed
            # while this job was running). The concurrency group prevents
            # bot-vs-bot races; this guards bot-vs-human.
            git push || (git pull --rebase --autostash && git push)
          else
            echo "No file changes (unexpected — run log should always be updated)."
          fi
